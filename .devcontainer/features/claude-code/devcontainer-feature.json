{
  "id": "claude-code",
  "version": "1.0.0",
  "name": "Claude Code CLI",
  "options": {
    "version": {
      "type": "string",
      "proposals": ["latest", "stable"],
      "default": "latest",
      "description": "Channel (latest|stable) or an exact version (major.minor.patch)"
    }
  },
  "containerEnv": {
    "PATH": "/home/ubuntu/.local/bin:${PATH}"
  }
}
