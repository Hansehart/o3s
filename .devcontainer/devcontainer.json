{
    // Name for the dev container
    "name": "o3s",
    // Deal with zombie processes
    "init": true,

    // Location of compose file
    "dockerComposeFile": "docker-compose.yml",
    // Which container from compose should be entered
    "service": "o3s",

    // Additional software layered onto the o3s image.
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker": {
            "version": "stable",
            // Docker CE
            "moby": false
        },
        "ghcr.io/devcontainers/features/kubectl-helm-minikube": {
            // kubectl
            "version": "stable",
            "helm": "latest",
            "minikube": "stable"
        },

        "ghcr.io/hansehart/devcontainer-features/claude-code:1": {
            "version": "stable",
            "configDir": "/home/ubuntu/config/claude"
        },
        "ghcr.io/hansehart/devcontainer-features/headless-chrome:1": {
            "version": "stable"
        },
        "ghcr.io/hansehart/devcontainer-features/latex:1": {
            "version": "2025"
        }
    },

    // Non-root user VS Code connects as
    "remoteUser": "ubuntu",
    // Which folder is the default inside the dev container
    "workspaceFolder": "/home/ubuntu/o3s",

    // Seed .env and the allowlist files from their templates if they don't exist yet
    "initializeCommand": "bash .devcontainer/hooks/initialize.sh",
    // Probe that egress reaches the gateway on every container start
    "postStartCommand": "bash .devcontainer/hooks/post-start.sh",

    // VSCode settings
    "customizations": {
        "vscode": {
            "settings": {
                "remote.autoForwardPorts": false
            }
        }
    }
}
