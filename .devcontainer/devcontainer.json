{
    // Name for the dev container
    "name": "o3s",
    // Deal with zombie processes
    "init": true,

    // Location of compose file
    "dockerComposeFile": "docker-compose.yml",
    // Which container from compose should be entered
    "service": "o3s",

    // Non-root user VS Code connects as (docker and firewall still run via sudo)
    "remoteUser": "codespace",
    // Which folder is the default inside the dev container
    "workspaceFolder": "/home/codespace/o3s",

    // Intialize .env variables (happens on docker host, only if .env does not exist yet)
    "initializeCommand": "cp -n .devcontainer/.env.template .devcontainer/.env && cp -n .devcontainer/allowed-domains.txt.template .devcontainer/allowed-domains.txt",
    // Execute start up script (inside dev container)
    "postCreateCommand": ".devcontainer/init.sh",
    // Start docker daemon and sett up firewall on every container start (before VS Code connects)
    "postStartCommand": "sudo /usr/local/share/docker-init.sh && sudo /usr/local/bin/firewall.sh .devcontainer/allowed-domains.txt",
    // TODO: parallelize postStartCommand for faster boot up
    // "waitFor": "postStartCommand",

    // VSCode settings
    "customizations": {
        "vscode": {
            "extensions": [
                // Container Tools
                "ms-azuretools.vscode-containers",
                // Data viewer
                "ms-toolsai.datawrangler",
                // GitHub Pull Requests and Issues
                "github.vscode-pull-request-github",
                // Google Colab (Remote kernel with GPU)
                "google.colab",
                // Jupyter notebooks (Local kernel)
                "ms-toolsai.jupyter",
                // LaTeX editing and compilation
                "james-yu.latex-workshop",
                // Python
                "ms-python.python"
            ]
        }
    }
}
