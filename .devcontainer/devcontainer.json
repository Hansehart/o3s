{
    // Name for the dev container
    "name": "o3s",
    // Deal with zombie processes
    "init": true,

    // Location of compose file
    "dockerComposeFile": "docker-compose.yml",
    // Which container from compose should be entered
    "service": "o3s",

    // Non-root user VS Code connects as (docker and firewall still run via sudo)
    "remoteUser": "codespace",
    // Which folder is the default inside the dev container
    "workspaceFolder": "/home/codespace/o3s",

    // Seed .env and the allowlist files from their templates if they don't exist yet
    "initializeCommand": "bash .devcontainer/commands/initialize.sh",
    // Start docker daemon and route egress through the gateway on every container start
    "postStartCommand": "bash .devcontainer/commands/post-start.sh",
    // Install extensions after VS Code attaches
    "postAttachCommand": "bash .devcontainer/commands/post-attach.sh",

    // VSCode settings
    "customizations": {
        "vscode": {
            "settings": {
                "remote.autoForwardPorts": false
            }
        }
    }
}
